        "name": "Аномалии Z-score",
        "target": {
          "dataset": "sensor_monitor",
          "editorMode": "code",
          "expr": "",
          "format": "table",
          "interval": "",
          "rawQuery": true,
          "rawSql": "SELECT                                                                                                                                                                 \n  r.timestamp AS time,\n  CONCAT('Z=', ROUND(r.z_score::numeric, 2), ' | ', s.name, ' / ', r.metric) AS text                                                                                   \nFROM sensor_analysis_result r                                                                                                                                          \n  JOIN sensor s ON s.id = r.sensor_id                                                                                                                                    \nWHERE r.detected = true                                                                                                                                                \n  AND r.analysis_type = 'ANOMALY_ZSCORE'                                                                                                                               \nORDER BY r.timestamp",
          "refId": "Anno",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      },
      {
        "datasource": {
          "type": "grafana-postgresql-datasource",
          "uid": "postgres"
        },
        "enable": true,
        "hide": false,
        "iconColor": "orange",
        "name": "Дрейф датчика",
        "target": {
          "dataset": "sensor_monitor",
          "editorMode": "code",
          "expr": "",
          "format": "table",
          "interval": "",
          "rawQuery": true,
          "rawSql": "SELECT          \n  r.timestamp AS time,\n  CONCAT('slope=', ROUND(r.slope::numeric, 3), ' | ', s.name, ' / ', r.metric) AS text\nFROM sensor_analysis_result r                                                         \n  JOIN sensor s ON s.id = r.sensor_id                                                                                                                                    \nWHERE r.detected = true            \n  AND r.analysis_type = 'DRIFT_LINEAR'                                                                                                                                 \nORDER BY r.timestamp",
          "refId": "Anno",
